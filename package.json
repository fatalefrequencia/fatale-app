{
  "name": "fatale-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "desktop-main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "npx wrangler pages deploy dist --project-name=fatale-app",
    "desktop": "electron .",
    "desktop:dev": "concurrently \"vite\" \"cross-env DESKTOP_URL=http://localhost:5173 electron .\"",
    "desktop:build": "vite build && electron-packager . fatale --platform=win32 --arch=x64 --out=dist-desktop --overwrite"
  },
  "dependencies": {
    "@microsoft/signalr": "^10.0.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@xyflow/react": "^12.10.2",
    "axios": "^1.13.2",
    "framer-motion": "^12.29.0",
    "lucide-react": "^0.563.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-youtube": "^10.1.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "vite": "^7.2.4",
    "wrangler": "^4.88.0"
  }
}
